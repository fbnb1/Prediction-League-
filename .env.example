# Copy to .env and adjust as needed. The .env file is gitignored.
# docker-compose.yml falls back to these same defaults if no .env is present.

# --- Database passwords ---
LEDGER_DB_PASSWORD=ledger
FIXTURE_DB_PASSWORD=fixture
PREDICTION_DB_PASSWORD=prediction

# --- Host port mappings ---
# Postgres mapped off 5432 to avoid clashing with a local Postgres install.
LEDGER_DB_PORT=5433
FIXTURE_DB_PORT=5434
PREDICTION_DB_PORT=5435
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
GATEWAY_PORT=8080

# --- RabbitMQ credentials ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Admin API key (guards admin endpoints on Fixture and Ledger) ---
ADMIN_API_KEY=dev-admin-key-change-me

# Copy to .env and adjust as needed. The .env file is gitignored.
# docker-compose.yml falls back to these same defaults if no .env is present.

# --- Database passwords ---
LEDGER_DB_PASSWORD=ledger
FIXTURE_DB_PASSWORD=fixture
PREDICTION_DB_PASSWORD=prediction

# --- Host port mappings ---
# Postgres mapped off 5432 to avoid clashing with a local Postgres install.
LEDGER_DB_PORT=5433
FIXTURE_DB_PORT=5434
PREDICTION_DB_PORT=5435
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
GATEWAY_PORT=8080

# --- Service host port mappings ---
LEDGER_SERVICE_PORT=8081
FIXTURE_SERVICE_PORT=8082
PREDICTION_SERVICE_PORT=8083

# --- JWT secret for the Prediction service ---
JWT_SECRET=dev-jwt-secret-change-me

# --- RabbitMQ credentials ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Admin API key (guards admin endpoints on Fixture and Ledger) ---
ADMIN_API_KEY=dev-admin-key-change-me

# --- The Odds API (real football fixtures + odds) ---
# Get a free key at https://the-odds-api.com (free tier: 500 requests/month).
# Leave ODDS_API_KEY empty to fall back to the bundled mock data.
ODDS_API_KEY=
#
# Quota budget (free tier = 500 requests/month):
#   odds request   = 2 credits   |   scores request = 2 credits
#   discovery (/sports) = free
# Pin ONE competition so each refresh costs only 2 credits. Leaving this empty
# auto-discovers ~35 leagues -> ~70 credits per refresh (drains the month fast).
#   World Cup:  soccer_fifa_world_cup
ODDS_API_SPORTS=soccer_fifa_world_cup
#
# ODDS_REFRESH_MINUTES: how often odds are re-pulled.
#   0    = pull once at startup (short acceptance test)
#   1440 = once a day -> ~2 credits/day  (recommended for a whole tournament)
ODDS_REFRESH_MINUTES=1440
#
# Whole-World-Cup estimate with the settings above: seed (2) + odds ~2/day +
# scores ~4 on match days  ~=  250-300 credits across the tournament, well
# inside the 500/month free tier (and the tournament spans two months).
# A hard quota guard also stops all calls once < 25 requests remain.
